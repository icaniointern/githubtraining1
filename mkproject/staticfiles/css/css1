
body{
    background-color: #f0f2f5;
    font-family: Arial, sans-serif;
    }

    .container{
        width: 500px;
        margin: 100px auto;
        padding: 30px;

        background-color: antiquewhite;
        border-radius: 10px;
        text-align: center;
        box-shadow: 0px 0px 10px gray;
    }

    h1{
        color: darkblue;
    }

    p{
        font-size: 18px;
        color: #333;
    }

    button{
        padding: 10px 20px;
        border: none;
        background-color: aqua;
        color: white;
        border-radius:5px;
        cursor: pointer; 
    }

    button:hover{
        background-color:darkblue;
    }